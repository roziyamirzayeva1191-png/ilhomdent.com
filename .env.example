# ==========================================================
# Dr Ilhom Dental Clinic — Environment Configuration
# Nusxa oling: cp .env.example .env  (va qiymatlarni to'ldiring)
# .env fayli HECH QACHON git'ga qo'shilmaydi!
# ==========================================================

# --- Majburiy (Production) ---

# JWT sessiya imzolash kaliti. Kamida 32 belgi, tasodifiy.
# Yaratish: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Birinchi ishga tushirishda admin hisobini yaratish uchun.
# ADMIN_PASSWORD kamida 8 belgi. Hisob yaratilgach bu qatorlarni o'chirish tavsiya etiladi.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Ixtiyoriy ---

# Sayt joylashgan URL (canonical/OG uchun ham nginx.conf da ishlatiladi)
APP_URL=https://drilhom.uz

# Server porti (standart: 3000)
PORT=3000

# Production rejimi (Docker'da avtomatik o'rnatiladi)
# NODE_ENV=production

# Ma'lumotlar joylashuvi (standart: ./data, ./backups, ./logs, ./public/uploads)
# DATA_DIR=
# BACKUPS_DIR=
# LOGS_DIR=
# UPLOADS_DIR=
# DEPLOY_DIR=
